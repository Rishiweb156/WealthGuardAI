# WealthGuard AI

# Python
PYTHONUNBUFFERED=1

# LLM Configuration
LLM_API_ENDPOINT=http://host.docker.internal:11434
LLM_MODEL_NAME=llama3.2:3b
LLM_TIMEOUT=30

# MLflow 
MLFLOW_TRACKING_URI=sqlite:///logs/mlruns/mlflow.db
MLFLOW_EXPERIMENT_NAME=WealthGuard_AI

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false #to prevent docker memory leaks, true for local development

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Graph RAG Settings
GRAPH_MIN_EDGE_WEIGHT=100
GRAPH_PAGERANK_ITERATIONS=100

# Forecasting Settings
FORECAST_CONFIDENCE_INTERVAL=0.85
FORECAST_MIN_HISTORICAL_DAYS=10

# Security
SECRET_KEY=dev-secret-key-change-in-prod
ALLOWED_ORIGINS=*