# Backend Dockerfile
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
# default-jre is required for tabula-py
RUN apt-get update && apt-get install -y \
    build-essential \
    default-jre \
    ghostscript \
    libmagic1 \
    poppler-utils \
    tesseract-ocr \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY pyproject.toml .

# Install dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e .

# Copy application code
COPY src/ ./src/
COPY llm_setup/ ./llm_setup/
COPY server.py ./
COPY config/ ./config/
COPY ui/ ./ui/

# Create directories
RUN mkdir -p data/input data/output/analysis data/output/charts logs/mlruns

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Run FastAPI
# NOTE: Removed --reload to prevent memory issues in Windows Docker
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]